# --- Server ------------------------------------------------
APP_ENV=development
APP_PORT=9090
APP_SECRET=change_me_to_random_32_byte_hex

# --- Database ----------------------------------------------
# Local dev: localhost:5499 | Docker: postgres:5432
DB_HOST=localhost
DB_PORT=5499
DB_NAME=porjar
DB_USER=porjar
DB_PASSWORD=porjar_dev
DB_SSL_MODE=disable
DB_MAX_CONNECTIONS=50
DB_IDLE_CONNECTIONS=10

# --- Redis -------------------------------------------------
# Local dev: localhost:6399 | Docker: redis:6379
REDIS_HOST=localhost
REDIS_PORT=6399
REDIS_PASSWORD=
REDIS_DB=0

# --- JWT ---------------------------------------------------
JWT_SECRET=change_me_to_different_random_32_byte_hex
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# --- File Upload -------------------------------------------
UPLOAD_DIR=./storage/uploads
UPLOAD_MAX_SIZE=5242880
UPLOAD_BASE_URL=http://localhost:9090/uploads

# --- CORS --------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:4200

# --- Rate Limiting -----------------------------------------
RATE_LIMIT_GLOBAL=100
RATE_LIMIT_LOGIN=5

# --- WebSocket ---------------------------------------------
WS_MAX_CONNECTIONS=5000
WS_PING_INTERVAL=30s
WS_IDLE_TIMEOUT=300s

# --- Async Submission Queue --------------------------------
# Number of worker goroutines processing the submission queue
SUBMISSION_WORKERS=10

# --- Logging -----------------------------------------------
LOG_LEVEL=debug
LOG_FORMAT=text
