FROM golang:1.26-alpine

RUN apk add --no-cache git curl

# Install air for hot reload
RUN go install github.com/air-verse/air@latest

WORKDIR /app

# Cache dependencies
COPY go.mod go.sum ./
RUN go mod download

# Copy source (volumes will override in dev)
COPY . .

EXPOSE 9090

CMD ["air", "-c", ".air.toml"]
